    "./task-list": {
      "types": "./dist/task-list/index.d.ts",
      "import": "./dist/task-list/index.js",
      "require": "./dist/task-list/index.cjs"
    },
    "./web-search": {
      "types": "./dist/web-search/index.d.ts",
      "import": "./dist/web-search/index.js",
      "require": "./dist/web-search/index.cjs"
    },
    "./tool-search": {
      "types": "./dist/tool-search/index.d.ts",
      "import": "./dist/tool-search/index.js",
      "require": "./dist/tool-search/index.cjs"
    },
    "./lsp": {
      "types": "./dist/lsp/index.d.ts",
      "import": "./dist/lsp/index.js",
      "require": "./dist/lsp/index.cjs"
    },
    "./http-request": {
      "types": "./dist/http-request/index.d.ts",
      "import": "./dist/http-request/index.js",
      "require": "./dist/http-request/index.cjs"
    },
    "./context-compaction": {
      "types": "./dist/context-compaction/index.d.ts",
      "import": "./dist/context-compaction/index.js",
      "require": "./dist/context-compaction/index.cjs"
    },
    "./ask-user": {
      "types": "./dist/ask-user/index.d.ts",
      "import": "./dist/ask-user/index.js",
      "require": "./dist/ask-user/index.cjs"
    },
    "./sleep": {
      "types": "./dist/sleep/index.d.ts",
      "import": "./dist/sleep/index.js",
      "require": "./dist/sleep/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:functional": "vitest run --project functional",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "ai": ">=5.0.17",
    "zod": ">=3.23.0"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.50",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ai": "^6.0.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.0"
  }
}
